CLIPLINE_IMAGE=ghcr.io/dain98/clipline-cloud:1.2.1
CLIPLINE_PUBLIC_URL=https://clips.example.com
CLIPLINE_HTTP_PORT=8080
CLIPLINE_BOOTSTRAP_ADMIN_USERNAME=admin

# Optional: set to the reverse proxy IP/CIDR if you want real client IPs from X-Forwarded-For.
CLIPLINE_TRUSTED_PROXY_HOPS=

# Optional: enable lossy post-upload H.264/AAC optimization.
CLIPLINE_VIDEO_OPTIMIZATION=off
CLIPLINE_VIDEO_OPTIMIZATION_CRF=26
CLIPLINE_VIDEO_OPTIMIZATION_PRESET=veryfast
CLIPLINE_VIDEO_OPTIMIZATION_MAX_WIDTH=0
CLIPLINE_VIDEO_OPTIMIZATION_MIN_SAVINGS_PERCENT=5
